{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build & Run Tic-Tac-Toe",
            "type": "shell",
            "command": "cmd.exe",
            "args": [
                "/c",
                "gcc src\\main.c -o bin\\game.exe -IC:\\GUI-Based-Tic-Tac-Toe\\include -LC:\\GUI-Based-Tic-Tac-Toe\\lib -lraylib -lopengl32 -lgdi32 -lwinmm && cd bin && .\\game.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}